    "Keep awake with lid closed" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "إبقاء الجهاز مستيقظًا والغطاء مغلق" }
        }
      }
    },
    "Keep display awake too" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "إبقاء الشاشة نشطة أيضًا" }
        }
      }
    },
    "Keeps your Mac awake while AI agents run." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "يُبقي Mac صاحيًا ما دام وكلاؤك يعملون." }
        }
      }
    },
    "Language" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "اللغة" }
        }
      }
    },
    "Launch at login" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "التشغيل عند تسجيل الدخول" }
        }
      }
    },
    "No agents detected" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "لم يُرصد أي وكيل نشط" }
        }
      }
