    },
    "System" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "النظام" }
        }
      }
    },
    "Tip: closing the lid sleeps the Mac unless “Keep awake with lid closed” is on." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "ملاحظة: إغلاق الغطاء يُنيم الجهاز ما لم يكن خيار «إبقاء الجهاز مستيقظًا والغطاء مغلق» مُفعّلًا." }
        }
      }
    },
    "⚠️ Sleep is disabled system-wide until you turn this off." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "⚠️ النوم مُعطّل على مستوى النظام حتى تُوقف هذا الخيار." }
        }
      }
    },
    "Version %@" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "الإصدار %@" }
        }
      }
    },
    "“مدلج” means one who journeys through the night — the Mac keeps working until your agents reach dawn." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : { "state" : "translated", "value" : "«مدلج» هو الذي يسري في الليل — يظل جهازك يعمل حتى تبلغ عواملك الفجر." }
        }
      }
    }
  },
  "version" : "1.0"
